# Deployable demo mode — khuyên dùng cho bản test nội bộ/cho người khác bấm thử.
NEXT_PUBLIC_DEMO_MODE="true"
GIAOAN_DEMO_MODE="true"
GIAOAN_ALLOW_DEMO_LOGIN="true"
NEXT_PUBLIC_DEPLOY_TARGET="vercel_or_render_demo"

# JSON fallback là đường chạy mặc định của bản demo này.
# Chỉ điền DATABASE_URL khi đã có PostgreSQL thật và muốn tự phát triển tiếp DB mode.
DATABASE_URL=""

# Font Unicode cho route xuất PDF nếu muốn PDF tiếng Việt đẹp hơn.
PDF_FONT_PATH=""

# Không đặt thì leader/admin demo quyền cao không dùng invite code thật.
GIAOAN_PRIVILEGED_LOGIN_CODE=""

# Local auth foundation.
GIAOAN_REQUIRE_EMAIL_VERIFICATION="false"
GIAOAN_AUTH_MAX_FAILED_LOGIN="8"
GIAOAN_AUTH_LOCK_MINUTES="15"

# Hosted demo / public test safety flags.
GIAOAN_PUBLIC_TEST_MODE="limited"
GIAOAN_DEMO_FEEDBACK_URL=""
GIAOAN_SMOKE_MODE="production"
NEXT_TELEMETRY_DISABLED="1"

# Batch86 hosted URL smoke (CI/local after deploy)
GIAOAN_DEMO_URL=""
VERCEL_AUTOMATION_BYPASS_SECRET=""
GIAOAN_HOSTED_URL_SMOKE_TIMEOUT_MS="18000"
